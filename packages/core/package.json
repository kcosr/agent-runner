{
  "name": "@kcosr/agent-runner-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared agent-runner business logic and helpers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/kcosr/agent-runner.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist/"],
  "exports": {
    "./app/*": "./dist/app/*",
    "./assignment/*": "./dist/assignment/*",
    "./backends/*": "./dist/backends/*",
    "./config/*": "./dist/config/*",
    "./contracts/*": "./dist/contracts/*",
    "./core/*": "./dist/core/*",
    "./hooks": "./dist/hooks.js",
    "./run-command.js": "./dist/run-command.js",
    "./agent-runner-command.js": "./dist/agent-runner-command.js",
    "./util/*": "./dist/util/*"
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc -b"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.4.2",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  }
}
