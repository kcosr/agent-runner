{
  "name": "task-runner-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Workspace root for the task-runner monorepo.",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "setup": "npm install",
    "build": "npm run build -w @task-runner/core && npm run build -w task-runner && node -e \"require('node:fs').chmodSync('apps/cli/dist/cli.js', 0o755)\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint-staged": "lint-staged",
    "check": "npm run build && npm run lint && node --test \"test/**/*.test.mjs\"",
    "test": "npm run build && node --test \"test/**/*.test.mjs\"",
    "prepack": "npm run build",
    "prepare": "husky install",
    "clean": "rimraf apps/*/dist packages/*/dist apps/*/tsconfig.tsbuildinfo packages/*/tsconfig.tsbuildinfo",
    "task-runner": "node apps/cli/dist/cli.js"
  },
  "lint-staged": {
    "!dist/**/*.{ts,tsx,js,jsx,mjs,cjs,json}": [
      "biome format --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.11.30",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
